# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://pixtager:password@localhost:5432/pixtager"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
UPLOAD_DIR=/tmp/pixtager
INTERNAL_KEY=change-me-secret

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-very-secret-key-min-32-chars
PASSWORD_SALT=change-me-salt-unique-per-installation

# ─── Yandex Geocoder API ──────────────────────────────────────────────────────
# Получить ключ: https://developer.tech.yandex.ru/
# Бесплатно: 25 000 запросов/день
YANDEX_GEOCODER_KEY=your_yandex_geocoder_key_here

# ─── T-Bank (Т-Банк) Acquiring ────────────────────────────────────────────────
# Получить: https://www.tbank.ru/kassa/
TINKOFF_TERMINAL_KEY=your_terminal_key
TINKOFF_PASSWORD=your_terminal_password

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=PixTager
