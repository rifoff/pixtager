{
  "name": "pixtager-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":    "nodemon --watch src --ext ts,js --exec 'node --loader ts-node/esm src/index.ts'",
    "start":  "node dist/index.js",
    "build":  "tsc",
    "worker": "node --loader ts-node/esm src/workers/imageWorker.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy":  "prisma migrate deploy",
    "db:studio":  "prisma studio"
  },
  "dependencies": {
    "fastify":              "^4.28.1",
    "@fastify/multipart":   "^8.3.0",
    "@fastify/cors":        "^9.0.1",
    "@fastify/rate-limit":  "^9.1.0",
    "bullmq":               "^5.12.12",
    "ioredis":              "^5.4.1",
    "sharp":                "^0.33.4",
    "archiver":             "^7.0.1",
    "exiftool-vendored":    "^28.3.1",
    "transliteration":      "^2.3.5",
    "uuid":                 "^10.0.0",
    "dotenv":               "^16.4.5",
    "prisma":               "^5.17.0",
    "@prisma/client":       "^5.17.0",
    "zod":                  "^3.23.8",
    "pino":                 "^9.3.2",
    "pino-pretty":          "^11.2.1"
  },
  "devDependencies": {
    "@types/node":     "^20",
    "@types/archiver": "^6.0.2",
    "@types/uuid":     "^10.0.0",
    "typescript":      "^5",
    "ts-node":         "^10.9.2",
    "nodemon":         "^3.1.4"
  }
}
